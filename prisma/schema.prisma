generator client {
  provider = "prisma-client-js"
}

generator client_py {
  provider      = "prisma-client-py"
  interface     = "asyncio"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id          String     @id @default(cuid())
  slug        String     @unique
  displayName String
  model       String
  role        AgentRole
  color       String
  isOnline    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  logs        AgentLog[]
  handoffs    Task[]     @relation("TaskHandoff")
  tasks       Task[]     @relation("TaskOwner")
}

model Task {
  id              String      @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus  @default(PENDING)
  priority        Int         @default(0)
  contextSnapshot Json?
  pineconeQueryIds String[]    @default([])
  ownerId         String
  handoffTargetId String?
  parentTaskId    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  logs            AgentLog[]
  executions      Execution[]
  handoffTarget   Agent?      @relation("TaskHandoff", fields: [handoffTargetId], references: [id])
  owner           Agent       @relation("TaskOwner", fields: [ownerId], references: [id])
}

model Execution {
  id            String     @id @default(cuid())
  taskId        String
  agentSlug     String
  model         String
  promptTokens  Int
  compTokens    Int
  thoughtChunks Json?
  sandboxId     String?
  result        Json?
  error         String?
  startedAt     DateTime   @default(now())
  finishedAt    DateTime?
  status        TaskStatus @default(RUNNING)
  task          Task       @relation(fields: [taskId], references: [id])
}

model AgentLog {
  id      String   @id @default(cuid())
  agentId String
  taskId  String?
  level   LogLevel @default(INFO)
  event   String
  payload Json?
  ts      DateTime @default(now())
  agent   Agent    @relation(fields: [agentId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
}

model KnowledgeChunk {
  id            String @id @default(cuid())
  source        String
  chunkIndex    Int
  content       String
  pineconeVecId String @unique
  metadata      Json
}

enum AgentRole {
  CTO
  BACKEND
  FRONTEND
  QA
  SUPPORT
  CM
  MAPPER
  BALANCER
  DEVOPS
  RESEARCH
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}
